{{#if result.shockIgnored}}
<p><strong>{{localize "CHAT.DETERMINATION_RESULT_IGNORE_SHOCK" wounds=result.wounds shock=result.converted}}</strong></p>
{{else}}
<p><strong>{{localize "CHAT.DETERMINATION_RESULT" wounds=result.wounds shock=result.converted}}</strong></p>
{{/if}}

{{#each result.text}}
<p><strong>{{this.label}}</strong>{{#if this.description}}: {{this.description}} {{/if}}</p>
{{/each}}
